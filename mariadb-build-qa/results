#!/bin/bash
set +H

DATADIR=/data

if [ ! -z "${1}" ]; then
  R_ONCEONLY=1  # Run once only, don't loop
fi

if [ -d "${DATADIR}" ]; then
  cd "${DATADIR}"
else
  echo "Assert: DATADIR (${DATADIR}) does not exist"
  exit 1
fi
if [ ! -r results.list ]; then
  echo "Assert: results.list does not exist. Terminating"
  exit 1
fi
source results.list  # This file should contain lines like: 
                     # MON[1]=532099
                     # MON[2]=398230
                     # MON[3]=032309
                     # Tip: when you've done multiple runs, you can change the 1,2,3 etc. for
                     # second/third etc. run sets to 11, 12, 13 then 21, 22, 23; gaps are fine
                     # etc. The file is sourced to allow this file to be backed up with results.list 
                     # being local to the machine/directory. Note: results.list is not backed up
                     # use 'return 0' anywhere in the script to stop processing the remainder of the file (handy to save old runs)
if [ -z "${R_ONCEONLY}" ]; then clear; fi  # Clear screen for normal (i.e. not-onceonly) runs

# Error-log scanning is delegated to ~/pr (pquery-results.sh) which calls
# error_log_scan.sh aggregate — the single source of truth for REGEX_ERRORS_SCAN
# / REGEX_ERRORS_LASTLINE / REGEX_ERRORS_FILTER. Output appears in pr's
# "** Significant/Major errors (if any)" section. No local scan needed.

# Loop dirs from results.list
while :; do
  DATADIR_LIST="#rm -Rf"  # Helpful delete aid text command creation (for output/display, not actual use in-script)
  for ((i=1;i<=1000;i++)); do
    if [ ! -z "${MON[${i}]}" ]; then
      if [ -d "${DATADIR}/${MON[${i}]}" ]; then
        DATADIR_LIST="${DATADIR_LIST} ${DATADIR}/${MON[${i}]}"
        cd "${DATADIR}/${MON[${i}]}"
        ~/pr | grep --binary-files=text -vEi '^=========$|^[ \t]+$|no reducer scripts were found in this directory' | sed '/Trials which /,+1d' | sed '/Trials with /,+1d' | sed '/SHUTDOWN/,+1d' | sed '/Coredumps found in trials/,+1d' | sed "s|^========== |========== [${i}] |"
      else
        echo "Index ${i} seems to be invalid: directory ${DATADIR}/${MON[${i}]} does not exist!"
        exit 1
      fi
    fi
  done
  if [ ! -z "${R_ONCEONLY}" ]; then exit 0; fi
  echo " ---------------------------------------------------------------------------------------------------------------"
  echo "Handy delete command if you want to remove all active datadirs in results.list:"
  echo "${DATADIR_LIST}"
  sleep 60
done
