#!/bin/bash

awk '/^[[:space:]]*return([[:space:]]|$)/{exit} /^MON/{sub(/.*=/,""); sub(/ .*/,""); print}' results.list \
  | xargs -P8 -I{} bash -c 'cd "{}" && ./my | sed "s|^[0-9]\+ .||;s|^|/|"' \
  | grep -v "/data$" \
  | xargs wc -l \
  | grep -v 'total$' \
  | awk '{
      lines=$1
      path=$2
      base=path
      sub(/(_out)+$/, "", base)
      suffix=substr(path, length(base)+1)
      n=gsub(/_out/, "&", suffix)
      if (!(base in best_n) || n > best_n[base]) {
        best_n[base]=n
        best_path[base]=path
        best_lines[base]=lines
      }
      sib[base]++
    }
    END {
      for (b in best_n) {
        printf "%d %s %d\n", best_lines[b], best_path[b], sib[b]-1
      }
    }' \
  | sort -n \
  | tac \
  | while read -r count path others; do
      if [ "$count" -eq 0 ]; then
        count_color='\033[31m'
      elif [ "$count" -le 8 ]; then
        count_color='\033[32m'
      elif [ "$count" -le 14 ]; then
        count_color='\033[33m'
      elif [ "$count" -le 39 ]; then
        count_color='\033[91m'
      else
        count_color='\033[31m'
      fi
      printf '%b%s\033[0m \033[1;32m%s\033[0m' "$count_color" "$count" "$path"
      if [ "$others" -gt 0 ]; then
        printf ' \033[38;5;88m+%s Other less reduced testcases for this trial\033[0m' "$others"
      fi
      printf '\n'
      trial_dir="${path%/*}"
      base="${trial_dir%/*}"
      trial="${trial_dir##*/}"
      reducer="${base}/reducer${trial}.sh"
      if [ -f "${trial_dir}/SHUTDOWN_TIMEOUT_ISSUE" ]; then
        printf '  \033[38;5;245m%s\033[0m\n' 'SHUTDOWN TIMEOUT >90 SEC ISSUE'
      elif [ -f "$reducer" ]; then
        text="$(grep "^   TEXT=" "$reducer" | head -n1 | sed 's|^   TEXT="||; s|"$||')"
        if [ ${#text} -gt 113 ]; then
          text="${text:0:113}..."
        fi
        printf '  \033[38;5;245m%s\033[0m\n' "$text"
      fi
    done
