#!/usr/bin/env bash
# Pick any Claude Code session across all projects and resume it.
# Usage:
#   clr               — show picker of 20 most recent sessions
#   clr <id-prefix>   — resume directly by (unique) session-id prefix, no picker
# Self-heals when a session's working dir was renamed/moved: resolves the
# renamed sibling dir, migrates the session-store folder to match, then resumes
# (Claude keys sessions by the physical cwd, so a symlink cannot stand in).
# Set CLR_DRYRUN=1 to resolve and heal but print the resume command instead of
# launching it.
# Created by Roel Van de Paar, MariaDB (with Claude Code assistance)

PROJECTS_DIR="${HOME}/.claude/projects"
LIMIT=20

if [ ! -d "$PROJECTS_DIR" ]; then
  echo "No $PROJECTS_DIR — nothing to resume." >&2
  exit 1
fi

ARG="${1:-}"

SELECTION="$(python3 - "$PROJECTS_DIR" "$LIMIT" "$ARG" <<'PYEOF'
import json, os, sys, time

projects_dir = sys.argv[1]
limit = int(sys.argv[2])
arg = sys.argv[3] if len(sys.argv) > 3 else ""

sessions = []
for dirpath, _, files in os.walk(projects_dir):
    if os.sep + "subagents" in dirpath:
        continue
    for f in files:
        if not f.endswith(".jsonl") or f.startswith("agent-"):
            continue
        path = os.path.join(dirpath, f)
        try:
            mtime = os.path.getmtime(path)
        except OSError:
            continue
        sid = f[:-6]
        sessions.append((mtime, sid, path))

sessions.sort(reverse=True)

def scan(path):
    """Return (first_user_cwd, first_real_prompt, ordered_cwds) in one pass."""
    first_user_cwd, prompt, cwds = "", "", []
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as fh:
            for line in fh:
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                c = obj.get("cwd") or ""
                if c:
                    cwds.append(c)
                if obj.get("type") != "user":
                    continue
                if not first_user_cwd and c:
                    first_user_cwd = c
                if prompt:
                    continue
                msg = obj.get("message") or {}
                content = msg.get("content")
                candidate = ""
                if isinstance(content, str):
                    candidate = content
                elif isinstance(content, list):
                    for block in content:
                        if isinstance(block, dict) and block.get("type") == "text":
                            candidate = block.get("text", "")
                            if candidate:
                                break
                stripped = candidate.lstrip()
                if stripped.startswith("<local-command-") or stripped.startswith("<command-") or stripped.startswith("<bash-"):
                    continue
                if candidate.strip():
                    prompt = candidate
    except OSError:
        pass
    return first_user_cwd, prompt, cwds

def resolve_target(cwds, first_cwd):
    """Existing dir to resume from; heals across renames. '' if undecidable."""
    if first_cwd and os.path.isdir(first_cwd):
        return first_cwd
    parent = os.path.dirname(first_cwd) if first_cwd else ""
    # 1) most-recent existing sibling cwd recorded in the transcript
    seen = set()
    for c in reversed(cwds):
        if c in seen:
            continue
        seen.add(c)
        if c == first_cwd:
            continue
        if os.path.isdir(c) and (not parent or os.path.dirname(c) == parent):
            return c
    # 2) unique renamed sibling sharing the leading "<N>" key
    if first_cwd and parent and os.path.isdir(parent):
        key = os.path.basename(first_cwd).split("-", 1)[0]
        if key:
            cands = []
            for d in os.listdir(parent):
                full = os.path.join(parent, d)
                if os.path.islink(full) or not os.path.isdir(full):
                    continue
                if d == key or d.startswith(key + "-"):
                    cands.append(full)
            if len(cands) == 1:
                return cands[0]
    return ""

# Direct-by-prefix mode: resolve against ALL sessions, not just the top 20.
if arg:
    matches = [(m, s, p) for (m, s, p) in sessions if s.startswith(arg.lower())]
    if not matches:
        print(f"No session id starts with '{arg}'.", file=sys.stderr)
        sys.exit(5)
    if len(matches) > 1:
        print(f"Prefix '{arg}' is ambiguous ({len(matches)} matches):", file=sys.stderr)
        for _, s, p in matches[:10]:
            fc, _, _ = scan(p)
            print(f"  {s[:8]}  {fc}", file=sys.stderr)
        sys.exit(6)
    _, sid, path = matches[0]
    fc, _, cwds = scan(path)
    target = resolve_target(cwds, fc)
    print(f"{sid}|{path}|{fc}|{target}")
    sys.exit(0)

sessions = sessions[:limit]

rows = []
for mtime, sid, path in sessions:
    fc, prompt, _ = scan(path)
    ts = time.strftime("%m-%d %H:%M", time.localtime(mtime))
    cwd_short = fc.replace(os.path.expanduser("~"), "~") if fc else "?"
    prompt_line = " ".join(prompt.split())[:90] if prompt else "(no user prompt)"
    rows.append((sid, path, ts, cwd_short, prompt_line))

if not rows:
    print("NONE", file=sys.stderr)
    sys.exit(2)

cwd_w = min(40, max((len(r[3]) for r in rows), default=10))
for sid, _, ts, cwd_short, prompt_line in rows:
    print(f"{sid[:8]}  {ts}  {cwd_short:<{cwd_w}.{cwd_w}}  {prompt_line}", file=sys.stderr)

print("", file=sys.stderr)
try:
    choice = input("Session id prefix (empty to cancel): ").strip().lower()
except EOFError:
    choice = ""
if not choice:
    sys.exit(3)

matches = [r for r in rows if r[0].startswith(choice)]
if not matches:
    print(f"No listed session starts with '{choice}'.", file=sys.stderr)
    sys.exit(4)
if len(matches) > 1:
    print(f"Prefix '{choice}' matches {len(matches)} sessions — be more specific.", file=sys.stderr)
    sys.exit(4)

sid, path, *_ = matches[0]
fc, _, cwds = scan(path)
target = resolve_target(cwds, fc)
print(f"{sid}|{path}|{fc}|{target}")
PYEOF
)"

rc=$?
[ $rc -ne 0 ] && exit $rc
[ -z "$SELECTION" ] && exit 0

IFS='|' read -r SID JPATH CWD0 TARGET <<<"$SELECTION"

enc() { printf '%s' "$1" | sed 's/[^A-Za-z0-9]/-/g'; }

if [ -z "$TARGET" ]; then
  echo "clr: working dir is gone and no renamed sibling was found:" >&2
  echo "       $CWD0" >&2
  echo "     cd into the dir this session now lives in, then run: claude --resume $SID" >&2
  exit 7
fi

# Heal the session store when the dir was renamed/moved: Claude finds a session
# only under the project folder that encodes the physical cwd, so migrate it.
NEWPROJ="$PROJECTS_DIR/$(enc "$TARGET")"
if [ -n "$JPATH" ]; then
  PROJ_OLD="$(dirname "$JPATH")"
  if [ "$PROJ_OLD" != "$NEWPROJ" ]; then
    if [ ! -e "$NEWPROJ" ]; then
      mv "$PROJ_OLD" "$NEWPROJ" || exit 1
    else
      mkdir -p "$NEWPROJ"
      mv -n "$PROJ_OLD"/* "$NEWPROJ"/ 2>/dev/null
      mv -n "$PROJ_OLD"/.[!.]* "$NEWPROJ"/ 2>/dev/null
      rmdir "$PROJ_OLD" 2>/dev/null
    fi
    echo "clr: dir renamed; migrated session store -> ${NEWPROJ##*/}" >&2
  fi
fi

if [ "$CWD0" != "$TARGET" ]; then
  echo "clr: '$CWD0' is gone; resuming in '$TARGET'" >&2
fi

if [ -n "${CLR_DRYRUN:-}" ]; then
  echo "clr[dryrun]: would run: (cd '$TARGET' && claude --resume $SID)" >&2
  if [ -f "$NEWPROJ/$SID.jsonl" ]; then
    echo "clr[dryrun]: session reachable at ${NEWPROJ##*/}/$SID.jsonl" >&2
  else
    echo "clr[dryrun]: WARNING session NOT found in target project folder" >&2
  fi
  exit 0
fi

cd "$TARGET" || exit 1
exec claude --resume "$SID"
